<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Gold Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_gold_bar"
            android:contentDescription="Gold bar"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOLD"
            android:textColor="#FFD700"
            android:textSize="11sp"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
    <TextView
        android:id="@+id/gold_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:textColor="#F0F0F0"
        android:textSize="20sp"/>
    <TextView
        android:id="@+id/gold_change"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+0.00%"
        android:textColor="#00E676"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"/>

    <!-- Silver Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_silver_bar"
            android:contentDescription="Silver bar"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SILVER"
            android:textColor="#C0C0C0"
            android:textSize="11sp"
            android:layout_marginStart="6dp"/>
    </LinearLayout>
    <TextView
        android:id="@+id/silver_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:textColor="#F0F0F0"
        android:textSize="20sp"/>
    <TextView
        android:id="@+id/silver_change"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+0.00%"
        android:textColor="#00E676"
        android:textSize="12sp"/>
</LinearLayout>
